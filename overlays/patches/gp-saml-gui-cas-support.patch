+    def parse_globalprotect_callback(self, uri):
+        if not uri.lower().startswith('globalprotectcallback:'):
+            return None
+
+        payload = unquote(uri.split(':', 1)[1]).strip()
+        if payload.startswith('/'):
+            payload = payload[1:]
+
+        if payload.startswith('cas-as'):
+            values = parse_qs(payload, keep_blank_values=True)
+            username = (values.get('un') or values.get('username') or [''])[0]
+            token = (values.get('token') or [''])[0]
+            if username and token:
+                return {
+                    'saml-username': username,
+                    'token': token,
+                }
+            return {}
+
+        try:
+            payload = a2b_base64(payload + '=' * (-len(payload) % 4)).decode('utf-8')
+        except Exception:
+            pass
+        return self.parse_saml_comments(payload)
+
+    def handle_globalprotect_callback(self, uri):
+        fd = self.parse_globalprotect_callback(uri)
+        if fd is None:
+            return False
+
+        if self.verbose:
+            print('[SAML   ] Got GlobalProtect callback URI', file=stderr)
+
+        if fd:
+            if self.verbose:
+                print('[SAML   ] Got SAML/CAS result data from GlobalProtect callback', file=stderr)
+            self.saml_result.update(fd)
+            self.saml_result.setdefault('server', self.server)
+            self.check_done()
+        elif self.verbose:
+            print('[SAML   ] GlobalProtect callback did not contain usable auth data', file=stderr)
+        return True
+
+    def handle_globalprotect_callback_from_content(self, content):
+        content = unescape(content)
+        match = re.search(r'globalprotectcallback:[^\s"\'<>]+', content, re.IGNORECASE)
+        if not match:
+            return False
+        return self.handle_globalprotect_callback(match.group(0))
+
+    def on_decide_policy(self, webview, decision, decision_type):
+        if decision_type != WebKit2.PolicyDecisionType.NAVIGATION_ACTION:
+            return False
+
+        action = decision.get_navigation_action()
+        request = action.get_request() if action else None
+        uri = request.get_uri() if request else None
+        if uri and self.handle_globalprotect_callback(uri):
+            decision.ignore()
+            return True
+        return False
+
+    def on_load_failed(self, webview, event, uri, error):
+        return self.handle_globalprotect_callback(uri or '')
+
